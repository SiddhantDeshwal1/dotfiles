# ~/.config/wofi/config
allow_images=false
allow_markup=false
insensitive=true  # Adjusted to true for case-insensitive matching, matching Rofi's false case-sensitive but fuzzy often ignores case
matching=fuzzy
term=kitty
prompt=search
width=450
lines=5
dynamic_lines=true
columns=1
orientation=vertical
hide_scroll=true
mode=drun,run  # Still no native window/ssh; consider external for those
layer=overlay
no_actions=true
key_up=Up
key_down=Down
sort_order=default
