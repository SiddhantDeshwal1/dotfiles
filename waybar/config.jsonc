                "№ѓЋ Рќ«Рќ«Рќ«Рќ»Рќ»Рќ»Рќ»Рќ»Рќ»Рќ»",
                "№ѓЋ Рќ«Рќ«Рќ«Рќ«Рќ»Рќ»Рќ»Рќ»Рќ»Рќ»",
                "№ѓЋ Рќ«Рќ«Рќ«Рќ«Рќ«Рќ»Рќ»Рќ»Рќ»Рќ»",
                "№ѓЋ Рќ«Рќ«Рќ«Рќ«Рќ«Рќ«Рќ»Рќ»Рќ»Рќ»",
                "№ѓЋ Рќ«Рќ«Рќ«Рќ«Рќ«Рќ«Рќ«Рќ»Рќ»Рќ»",
                "№ѓЋ Рќ«Рќ«Рќ«Рќ«Рќ«Рќ«Рќ«Рќ«Рќ»Рќ»",
                "№ѓЋ Рќ«Рќ«Рќ«Рќ«Рќ«Рќ«Рќ«Рќ«Рќ«Рќ»",
                "№ѓЋ Рќ«Рќ«Рќ«Рќ«Рќ«Рќ«Рќ«Рќ«Рќ«Рќ«"
            ],
            "car": [
                "№є╣ Рќ»Рќ»Рќ»Рќ»Рќ»Рќ»Рќ»Рќ»Рќ»Рќ»",
                "№є╣ Рќ«Рќ»Рќ»Рќ»Рќ»Рќ»Рќ»Рќ»Рќ»Рќ»",
                "№є╣ Рќ«Рќ«Рќ»Рќ»Рќ»Рќ»Рќ»Рќ»Рќ»Рќ»",
