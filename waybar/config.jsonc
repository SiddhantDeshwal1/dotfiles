{
    "layer": "top",
    "modules-left": [
        "hyprland/workspaces",
        "custom/separator1",
        "custom/timer",
        "custom/separator",
        "custom/todo",
        "custom/separator",
        "tray",
    ],
    "modules-center": [],
    "modules-right": [
        "custom/cpu",
        "custom/separator",
        "custom/gpu",
        "custom/separator",
        "custom/memory",
        "custom/separator",
        "pulseaudio#output",
        "custom/separator",
        "pulseaudio#mic",
        "custom/separator",
        "custom/clock",
        "custom/separator",
        "battery"
    ],
    // Separators
    "custom/rule": {
        "exec": "echo 'WPAS_PCSR'",
    },
    "custom/separator": {
        "exec": "echo ' '",
        "interval": 0,
        "format": "{}",
        "tooltip": false
    },
    "custom/separator1": {
        "exec": "echo ' '",
        "interval": 0,
        "format": "{}",
        "tooltip": false
    },
    "custom/separator2": {
        "exec": "echo '  '",
        "interval": 0,
        "format": "{}",
        "tooltip": false
    },
    // ­Ъјх Audio Output
    "pulseaudio#output": {
        "format": "V:{volume}%",
        "format-bluetooth": "{icon} №іћ {volume}%",
        "format-bluetooth-muted": "№Љд {icon} №іћ",
        "format-muted": "M",
        "format-icons": {
            "headphone": [
